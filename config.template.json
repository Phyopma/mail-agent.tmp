{
  "timezone": "America/Los_Angeles",
  "batch_size": 5,
  "log_level": "INFO",
  "accounts_file": "accounts.json",
  "gemini_model": "gemini-2.5-flash-lite",
  "gemini_temperature": 0.1,
  "gemini_max_output_tokens": 2048,
  "gemini_timeout": 60,
  "enable_multimodal_fallback": true,
  "push_enabled": true,
  "gmail_watch_topic": "projects/YOUR_PROJECT_ID/topics/mail-agent-gmail-watch",
  "trigger_tasks_queue": "mail-agent-trigger",
  "trigger_service_url": "https://mail-agent-trigger-xxxxx-uc.a.run.app",
  "trigger_job_name": "mail-agent-job",
  "trigger_debounce_seconds": 60,
  "trigger_min_execution_gap_seconds": 120,
  "watch_renew_schedule": "0 6 * * *",
  "classification_repair_enabled": true,
  "tool_extraction_enabled": true,
  "enforce_both_labels": true,
  "spam_disposition": "trash",
  "cleanup_spam_failsafe": true,
  "sender_unread_window_days": 30,
  "sender_unread_threshold": 10,
  "sender_overload_policy": "force_ignore",
  "ignore_disposition": "archive",
  "ignore_cleanup_days": 7,
  "multimodal_max_attachments": 3,
  "multimodal_max_attachment_bytes": 2000000,
  "labels": {
    "processed": "ProcessedByAgent",
    "spam": "Spam",
    "work": "Work",
    "personal": "Personal",
    "important": "Important",
    "urgent": "Urgent"
  }
}
